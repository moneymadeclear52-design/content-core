# content-core — shared environment variables
# Copy to .env in each pipeline repo and fill in your own values.
# NEVER commit .env. Only .env.example is committed.

# ─── LLM providers ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key        # optional
GEMINI_API_KEY=your-gemini-api-key        # optional

LLM_PROVIDER=claude                        # claude | openai | gemini
LLM_DEFAULT_MODEL=claude-sonnet-4-6        # optional; provider default used if unset

# Originality injector model overrides (optional; sensible defaults baked in)
INJECTOR_MODEL=claude-sonnet-4-6
INJECTOR_RATE_MODEL=claude-haiku-4-5-20251001

# ─── Notion (Perspective Bank) ─────────────────────────────────────────────
NOTION_TOKEN=your-notion-integration-token
# DB IDs have defaults baked in; only set to override:
# PERSPECTIVE_DB_ID=
# FRAMEWORKS_DB_ID=
# VOICE_ASSETS_DB_ID=
# GATES_DB_ID=
